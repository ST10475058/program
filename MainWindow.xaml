<Window x:Class="CybersecurityChatbotPOE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔒 Cybersecurity Awareness Chatbot" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D1B2A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art -->
        <Border Grid.Row="0" Background="#1B263B" BorderBrush="#2ECC71" BorderThickness="0,0,0,2">
            <TextBlock x:Name="AsciiArtDisplay" FontFamily="Consolas" FontSize="9" 
                       Foreground="#2ECC71" TextAlignment="Center" 
                       TextWrapping="Wrap" Margin="10"/>
        </Border>

        <!-- Button Bar -->
        <Border Grid.Row="1" Background="#0D1B2A" BorderBrush="#415A77" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button x:Name="AddTaskBtn" Content="➕ Add Task" Click="AddTaskBtn_Click" 
                        Width="100" Height="35" Margin="5" Background="#415A77" Foreground="White"/>
                <Button x:Name="ShowTasksBtn" Content="📋 My Tasks" Click="ShowTasksBtn_Click" 
                        Width="100" Height="35" Margin="5" Background="#415A77" Foreground="White"/>
                <Button x:Name="QuizBtn" Content="🎮 Take Quiz" Click="QuizBtn_Click" 
                        Width="100" Height="35" Margin="5" Background="#415A77" Foreground="White"/>
                <Button x:Name="LogBtn" Content="📊 Activity Log" Click="LogBtn_Click" 
                        Width="110" Height="35" Margin="5" Background="#415A77" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="2" Background="#0D1B2A">
            <StackPanel x:Name="ChatPanel" Margin="10"/>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#0D1B2A" Height="30">
            <StackPanel Orientation="Horizontal" Margin="15,5,0,0">
                <TextBlock x:Name="DbStatusText" Text="💾 Database: Checking..." Foreground="#F39C12" FontSize="12"/>
                <TextBlock x:Name="TypingIndicator" Text="🛡️ Ready" Foreground="#2ECC71" FontSize="12" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="4" Background="#1B263B" BorderBrush="#415A77" BorderThickness="0,2,0,0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputTextBox" Grid.Column="0" Height="40" FontSize="14"
                         Background="#0D1B2A" Foreground="#E0E1DD" BorderBrush="#415A77" 
                         BorderThickness="2" Padding="10,8" KeyDown="InputTextBox_KeyDown"/>
                <Button x:Name="SendButton" Grid.Column="1" Content="📤 SEND" 
                        Width="80" Height="40" Margin="10,0,0,0" Click="SendButton_Click"
                        Background="#2ECC71" Foreground="White" FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</Window>